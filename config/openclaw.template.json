{
  "browser": {
    "headless": true,
    "noSandbox": true
  },
  "secrets": {
    "providers": {
      "azure-key-vault": {
        "source": "exec",
        "command": "/usr/local/bin/openclaw-keyvault-resolver",
        "args": [
          "--vault-name",
          "YOUR_KEY_VAULT_NAME"
        ],
        "timeoutMs": 10000,
        "noOutputTimeoutMs": 5000,
        "maxOutputBytes": 65536,
        "jsonOnly": true,
        "trustedDirs": [
          "/usr/local/bin"
        ]
      }
    },
    "defaults": {
      "exec": "azure-key-vault"
    },
    "resolution": {
      "maxProviderConcurrency": 4,
      "maxRefsPerProvider": 64,
      "maxBatchBytes": 65536
    }
  },
  "auth": {
    "profiles": {
      "github-copilot:github": {
        "provider": "github-copilot",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "github-copilot/claude-sonnet-5",
        "fallbacks": [
          "github-copilot/gpt-5.6-sol"
        ]
      },
      "thinkingDefault": "high",
      "models": {
        "github-copilot/claude-opus-4.6": {
          "alias": "previous-primary-opus"
        },
        "github-copilot/claude-sonnet-4.6": {
          "alias": "fallback-sonnet"
        },
        "github-copilot/gemini-2.5-pro": {
          "alias": "fallback-gemini"
        },
        "github-copilot/claude-opus-4.8": {
          "alias": "benchmark-opus-4-8"
        },
        "github-copilot/claude-sonnet-5": {
          "alias": "primary-sonnet-5"
        },
        "github-copilot/gpt-5.6-sol": {
          "alias": "fallback-gpt-5-6-sol"
        }
      },
      "workspace": "/home/azureuser/.openclaw/workspace",
      "verboseDefault": "on",
      "maxConcurrent": 4,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 50000
      },
      "subagents": {
        "delegationMode": "suggest",
        "maxConcurrent": 4,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 3,
        "model": "github-copilot/claude-sonnet-4.6",
        "thinking": "medium",
        "runTimeoutSeconds": 2700
      },
      "memorySearch": {
        "provider": "github-copilot",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        },
        "enabled": true
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "YOUR_AGENT_NAME",
          "emoji": "🤖"
        }
      },
      {
        "id": "orchestrator",
        "workspace": "/home/azureuser/.openclaw/workspace",
        "model": "github-copilot/claude-sonnet-4.6",
        "identity": {
          "name": "Orchestrator",
          "emoji": "🎯"
        }
      }
    ]
  },
  "memory": {
    "backend": "builtin",
    "citations": "auto"
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": [
      "group:web",
      "message"
    ],
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave"
      }
    },
    "experimental": {
      "planTool": true
    },
    "toolSearch": {
      "enabled": true,
      "mode": "directory",
      "searchDefaultLimit": 8,
      "maxSearchLimit": 20
    },
    "sessions": {
      "visibility": "agent"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "suppressToolErrors": false
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "identityLinks": {
      "YOUR_USERNAME": [
        "telegram:YOUR_TELEGRAM_USER_ID",
        "discord:YOUR_DISCORD_USER_ID"
      ]
    }
  },
  "channels": {
    "telegram": {
      "dmPolicy": "allowlist",
      "botToken": {
        "source": "exec",
        "provider": "azure-key-vault",
        "id": "TELEGRAM-BOT-TOKEN"
      },
      "allowFrom": [
        "YOUR_TELEGRAM_USER_ID"
      ],
      "groupPolicy": "disabled",
      "streaming": {
        "mode": "partial"
      }
    },
    "discord": {
      "enabled": true,
      "token": {
        "source": "exec",
        "provider": "azure-key-vault",
        "id": "DISCORD-BOT-TOKEN"
      },
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "YOUR_DISCORD_USER_ID"
      ],
      "dm": {
        "enabled": true
      },
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": true,
          "toolsBySender": {
            "YOUR_DISCORD_USER_ID": {
              "allow": ["*"]
            },
            "*": {
              "deny": ["exec", "write", "edit", "gateway", "cron"]
            }
          },
          "users": ["*"],
          "channels": {
            "YOUR_AGENT_CHANNEL_ID": {
              "requireMention": false
            },
            "*": {}
          }
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": {
        "source": "exec",
        "provider": "azure-key-vault",
        "id": "OPENCLAW-GATEWAY-TOKEN"
      },
      "allowTailscale": true
    },
    "tailscale": {
      "mode": "serve"
    }
  },
  "plugins": {
    "allow": [
      "brave",
      "browser",
      "discord",
      "github-copilot",
      "memory-core",
      "telegram"
    ],
    "entries": {
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": {
              "source": "exec",
              "provider": "azure-key-vault",
              "id": "BRAVE-API-KEY"
            }
          }
        }
      },
      "discord": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      }
    }
  },
  "diagnostics": {
    "enabled": true,
    "memoryPressureSnapshot": true
  },
  "logging": {
    "level": "info",
    "file": "/var/log/openclaw/openclaw.log",
    "maxFileBytes": 104857600,
    "consoleLevel": "info",
    "consoleStyle": "compact",
    "redactSensitive": "tools"
  }
}
